---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FlaskConical, Layers3, MapPinned, Mountain } from 'lucide-react';
import {
  INAM_EXPERIMENTAL_CENTERS,
  INAM_LABS,
  INAM_REFERENCE_IMAGES,
  INAM_RESEARCH_CENTERS,
  INAM_SOURCE,
} from '@utils/inam-data';
---

<BaseLayout
  title="Infraestructura y Territorio | INAM"
  description="Centros de investigación, laboratorios y centros experimentales visibles en la fuente oficial consultada para el INAM de la UNTRM."
>
  <section class="relative overflow-hidden bg-[var(--color-accent-deep)] text-white">
    <div class="absolute inset-0">
      <img src={INAM_REFERENCE_IMAGES.centers} alt="Imagen de centros de investigación en la referencia oficial del INAM" class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(16,44,40,0.92),rgba(16,44,40,0.76),rgba(16,44,40,0.42))]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="max-w-4xl space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white/60">Infraestructura y Territorio</p>
        <h1 class="font-[var(--font-display)] text-5xl leading-tight sm:text-6xl">
          Centros, laboratorios y estaciones de campo organizados en una sola vista.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-white/78">
          La referencia oficial consultada publica 16 centros de investigación, 7 laboratorios y 7 centros experimentales. Aquí se reúnen para ahorrar navegación y mantener continuidad entre infraestructura científica y despliegue territorial.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-white/15 bg-white/8 p-5 backdrop-blur">
          <p class="font-[var(--font-display)] text-4xl">{INAM_RESEARCH_CENTERS.length}</p>
          <p class="mt-2 text-sm text-white/70">centros de investigación</p>
        </div>
        <div class="rounded-3xl border border-white/15 bg-white/8 p-5 backdrop-blur">
          <p class="font-[var(--font-display)] text-4xl">{INAM_LABS.length}</p>
          <p class="mt-2 text-sm text-white/70">laboratorios y plataformas técnicas</p>
        </div>
        <div class="rounded-3xl border border-white/15 bg-white/8 p-5 backdrop-blur">
          <p class="font-[var(--font-display)] text-4xl">{INAM_EXPERIMENTAL_CENTERS.length}</p>
          <p class="mt-2 text-sm text-white/70">estaciones y centros experimentales</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="flex max-w-3xl flex-col gap-4">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">Centros de Investigación</p>
      <h2 class="font-[var(--font-display)] text-4xl leading-tight text-[var(--color-ink)] sm:text-5xl">
        Colección visible en la fuente oficial consultada
      </h2>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {INAM_RESEARCH_CENTERS.map((center) => (
        <article class="rounded-[2rem] border border-[var(--color-border)] bg-white p-8 shadow-sm">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--color-surface-strong)] text-[var(--color-accent)]">
            <Layers3 className="h-6 w-6" />
          </div>
          <h3 class="mt-6 font-[var(--font-display)] text-3xl leading-tight text-[var(--color-ink)]">{center.title}</h3>
          <p class="mt-5 text-base leading-8 text-[var(--color-body)]">
            {center.coordinator ? <><strong>Coordinación:</strong> {center.coordinator}</> : 'Sin coordinación visible en el bloque oficial consultado.'}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface)] p-8">
      <div class="flex max-w-3xl flex-col gap-4">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">Laboratorios</p>
        <h2 class="font-[var(--font-display)] text-4xl leading-tight text-[var(--color-ink)]">Soporte experimental y técnico</h2>
      </div>

      <div class="mt-10 grid gap-4 lg:grid-cols-2">
        {INAM_LABS.map((lab) => (
          <div class="flex items-start gap-4 rounded-2xl border border-[var(--color-border)] bg-white/85 px-5 py-4">
            <FlaskConical className="mt-1 h-5 w-5 shrink-0 text-[var(--color-accent)]" />
            <p class="text-base leading-7 text-[var(--color-body)]">{lab}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-[var(--color-border)] bg-white p-8 shadow-sm">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div class="space-y-4">
          <p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-muted)]">Centros Experimentales</p>
          <h2 class="font-[var(--font-display)] text-4xl leading-tight text-[var(--color-ink)]">
            Presencia regional para validación, conservación y transferencia
          </h2>
          <p class="text-base leading-8 text-[var(--color-body)]">
            En la referencia oficial, los centros experimentales aparecen como un bloque independiente. Aquí quedan integrados a la infraestructura del instituto porque son parte de la misma capacidad científica desplegada en territorio.
          </p>
          <div class="overflow-hidden rounded-[1.8rem] border border-[var(--color-border)]">
            <img
              src={INAM_REFERENCE_IMAGES.experimental}
              alt="Imagen de centros experimentales en la referencia oficial del INAM"
              class="h-72 w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {INAM_EXPERIMENTAL_CENTERS.map((center) => (
            <article class="rounded-[1.8rem] border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
              <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white text-[var(--color-accent)]">
                <Mountain className="h-5 w-5" />
              </div>
              <h3 class="mt-5 font-[var(--font-display)] text-2xl leading-tight text-[var(--color-ink)]">{center.title}</h3>
              <p class="mt-3 text-sm font-semibold text-[var(--color-accent)]">{center.location}</p>
              <p class="mt-4 text-sm leading-7 text-[var(--color-body)]">{center.summary}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="mt-10 flex items-start gap-4 rounded-2xl border border-dashed border-[var(--color-border-strong)] bg-white/60 p-5">
        <MapPinned className="mt-1 h-5 w-5 shrink-0 text-[var(--color-accent)]" />
        <p class="text-sm leading-7 text-[var(--color-body)]">
          El inventario visible se tomó del feed oficial consultado el 20 de abril de 2026 y las imágenes de esta página también se apoyan en assets publicados por la referencia oficial: <a href={INAM_SOURCE.dataFeed} target="_blank" rel="noopener noreferrer" class="font-semibold text-[var(--color-accent)]">fuente JSON del INAM</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
