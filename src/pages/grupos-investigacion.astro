---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowUpRight, Microscope, Users } from 'lucide-react';
import { INAM_GROUPS, INAM_REFERENCE_IMAGES, INAM_SOURCE } from '@utils/inam-data';
---

<BaseLayout
  title="Grupos de Investigación | INAM"
  description="Página de grupos de investigación del INAM, construida a partir del feed oficial consultado de la UNTRM."
>
  <section class="relative overflow-hidden bg-[var(--color-accent-deep)] text-white">
    <div class="absolute inset-0">
      <img src={INAM_REFERENCE_IMAGES.heroSecondary} alt="Banner oficial de referencia del INAM" class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(16,44,40,0.92),rgba(16,44,40,0.74),rgba(16,44,40,0.4))]"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="max-w-4xl space-y-6">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-white/60">Grupos de Investigación</p>
        <h1 class="font-[var(--font-display)] text-5xl leading-tight sm:text-6xl">
          Líneas activas de trabajo científico articuladas en grupos temáticos.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-white/78">
          El feed oficial consultado muestra 19 grupos de investigación vinculados a cambio climático, biodiversidad, aguas, suelos, sanidad vegetal y tecnologías ambientales.
        </p>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-white/15 bg-white/8 p-5 backdrop-blur">
          <p class="font-[var(--font-display)] text-4xl">{INAM_GROUPS.length}</p>
          <p class="mt-2 text-sm text-white/70">grupos visibles en la fuente oficial</p>
        </div>
        <div class="rounded-3xl border border-white/15 bg-white/8 p-5 backdrop-blur">
          <p class="font-[var(--font-display)] text-4xl">Amazonas</p>
          <p class="mt-2 text-sm text-white/70">territorio de aplicación y transferencia</p>
        </div>
        <div class="rounded-3xl border border-white/15 bg-white/8 p-5 backdrop-blur">
          <p class="font-[var(--font-display)] text-4xl">UNTRM</p>
          <p class="mt-2 text-sm text-white/70">articulación institucional de investigación</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {INAM_GROUPS.map((group) => (
        <article class="rounded-[2rem] border border-[var(--color-border)] bg-white p-8 shadow-sm">
          <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--color-surface-strong)] text-[var(--color-accent)]">
            <Microscope className="h-6 w-6" />
          </div>
          <h2 class="mt-6 font-[var(--font-display)] text-3xl leading-tight text-[var(--color-ink)]">{group.title}</h2>
          <p class="mt-5 text-base leading-8 text-[var(--color-body)]">
            <strong>Investigador titular:</strong> {group.lead}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface)] p-8">
      <div class="flex items-start gap-4">
        <Users className="mt-1 h-6 w-6 text-[var(--color-accent)]" />
        <div class="space-y-3">
          <h2 class="font-[var(--font-display)] text-3xl text-[var(--color-ink)]">Referencia oficial</h2>
          <p class="max-w-3xl text-base leading-8 text-[var(--color-body)]">
            Los grupos mostrados aquí fueron recuperados del feed oficial del INAM consultado el 20 de abril de 2026.
          </p>
          <a
            href={INAM_SOURCE.dataFeed}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)]"
          >
            Ver feed oficial consultado
            <ArrowUpRight className="h-4 w-4" />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
